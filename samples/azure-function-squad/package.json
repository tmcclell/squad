{
  "name": "@squad-samples/azure-function-squad",
  "version": "1.0.0",
  "private": true,
  "description": "Azure Function + Content Review Squad — Squad SDK sample",
  "type": "module",
  "main": "dist/functions/squad-prompt.js",
  "scripts": {
    "build": "tsc",
